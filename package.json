{
  "name": "unu-raymi-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "postinstall": "node -e \"const t=process.env.APP_TYPE||'all'; if(t==='backend'||t==='all'){require('child_process').execSync('npm install',{cwd:'backend',stdio:'inherit'})} if(t==='admin'||t==='all'){require('child_process').execSync('npm install',{cwd:'admin',stdio:'inherit'})} if(t==='frontend'||t==='all'){require('child_process').execSync('npm install',{cwd:'frontend',stdio:'inherit'})}\"",

    "install:backend": "cd backend && npm install",
    "build:backend": "cd backend && npm run build",
    "start:backend": "APP_TYPE=backend node server.js",

    "install:admin": "cd admin && npm install",
    "build:admin": "cd admin && npm run build",
    "start:admin": "APP_TYPE=admin node server.js",

    "install:frontend": "cd frontend && npm install",
    "build:frontend": "cd frontend && npm run build",
    "start:frontend": "APP_TYPE=frontend node server.js"
  }
}
