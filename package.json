{
  "name": "unu-raymi-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "cd backend && npm install && cd ../admin && npm install && cd ../frontend && npm install",
    "install:backend": "cd backend && npm install",
    "build:backend": "cd backend && npm run build",
    "start:backend": "cd backend && npm run start",

    "install:admin": "cd admin && npm install",
    "build:admin": "cd admin && npm run build",
    "start:admin": "cd admin && npm run start -- -p $PORT",

    "install:frontend": "cd frontend && npm install",
    "build:frontend": "cd frontend && npm run build",
    "start:frontend": "cd frontend && npm run start -- -p $PORT"
  }
}
