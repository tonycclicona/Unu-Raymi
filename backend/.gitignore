# ── Dependencias ──────────────────────────────────
node_modules/

# ── Variables de entorno (SOLO .env.production y .env.example se commitean) ──
.env
.env.local

# ── Base de datos local (SQLite para desarrollo) ──
prisma/dev.db
prisma/dev.db-journal

# ── Archivos subidos y generados (se crean en el servidor) ──
storage/uploads/*
storage/invoices/*
!storage/uploads/.gitkeep
!storage/invoices/.gitkeep

# ── Build y distribución ──────────────────────────
dist/

# ── Logs ──────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*

# ── Misc ──────────────────────────────────────────
.DS_Store
