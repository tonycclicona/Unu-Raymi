{
  "name": "unu-raymi-backend",
  "version": "1.0.0",
  "description": "API Backend para el Sistema de Reservas de Tours Unu-Raymi",
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "prisma generate && prisma db push --accept-data-loss",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:local:generate": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "db:local:push": "prisma db push --schema=prisma/schema.sqlite.prisma"
  },
  "keywords": [
    "tours",
    "reservas",
    "express",
    "prisma",
    "mysql"
  ],
  "author": "Unu-Raymi Dev Team",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.9",
    "pdfkit": "^0.18.0",
    "prisma": "^5.22.0",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}

