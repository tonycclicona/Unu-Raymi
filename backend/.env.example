# ============================================================
# ENV VARIABLES - Unu-Raymi Backend
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a control de versiones (está en .gitignore)
# ============================================================

# Puerto del servidor Express
PORT=4000

# URL de conexión a MySQL en Hostinger
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://tu_usuario:tu_password@tu_host_hostinger:3306/unu_raymi_db"

# Entorno de ejecución
NODE_ENV=development

# Clave secreta para verificación de Webhook (Stripe / Mercado Pago)
WEBHOOK_SECRET="cambia_esta_clave_secreta_por_una_real"

# Clave secreta del Webhook de Stripe (Dashboard → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET="whsec_..."

# URL pública del backend (para construir links del invoice en emails)
API_BASE_URL="http://localhost:4000"

# URL del frontend (para CORS)
FRONTEND_URL="http://localhost:3000"

# ── SMTP (Hostinger) ─────────────────────────────────────────
# Hostinger: smtp.hostinger.com | Puerto 465 (SSL) ó 587 (TLS)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="info@tu-dominio.com"
SMTP_PASS="tu_password_del_correo"

# ── AUTENTICACIÓN JWT & ADMIN ────────────────────────────────
JWT_SECRET="alguna_clave_secreta_y_larga_de_jwt_2026"
ADMIN_USER="admin"
ADMIN_PASS="admin123"

# Resend API Key para envío de correos confirmados (Dashboard -> API Keys)
RESEND_API_KEY="re_..."
